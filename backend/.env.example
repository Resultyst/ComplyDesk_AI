# ────────────────────────────────────────────────────────
# ComplyDesk — Environment Variables Example Configuration
# ────────────────────────────────────────────────────────

# Hindsight Cloud Memory Settings
HINDSIGHT_API_KEY=your_hindsight_api_key_here
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_NAMESPACE=complydesk-fintech

# Groq LLM Cloud Settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_LOW_SENSITIVITY=openai/gpt-oss-120b

# Ollama LLM Local Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=llama3:8b
OLLAMA_MODEL_FALLBACK=llama3:8b
